{
  "name": "gmail-automation",
  "version": "1.0.0",
  "description": "Gmail Automation Suite with AI categorization, retention management, and job tracking",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:integration": "jest tests-local/api-service.integration.test.js",
    "test:unit": "jest --testPathIgnorePatterns=integration",
    "test:all": "bash scripts/run-all-tests.sh",
    "test:gas-compat": "jest tests-local/gas-global-scope.test.js tests-local/service-adapters.test.js",
    "test:gas-full": "node scripts/validate-gas-compatibility.js",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "predeploy": "npm run test:gas-full",
    "deploy": "clasp push",
    "deploy:safe": "npm run test:gas-full && clasp push",
    "deploy:watch": "clasp push --watch",
    "open": "clasp open",
    "pull": "clasp pull",
    "logs": "clasp logs"
  },
  "keywords": [
    "gmail",
    "automation",
    "google-apps-script",
    "ai",
    "email-management"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/google-apps-script": "^1.0.100",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "jsdom": "^27.0.0",
    "nock": "^14.0.10",
    "sinon": "^21.0.0"
  }
}
